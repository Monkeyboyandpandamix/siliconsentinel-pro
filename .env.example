# ─── AI Provider ───────────────────────────────────────────────────────────────
# Options: "gemini" (default) | "watsonx"
AI_PROVIDER=gemini

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# ─── IBM watsonx Foundation Model ──────────────────────────────────────────────
# Required when AI_PROVIDER=watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─── IBM Watson Neural Text-to-Speech ─────────────────────────────────────────
# Obtain from IBM Cloud → Watson Text to Speech → Service credentials
# API key + service URL (e.g. https://api.us-east.text-to-speech.watson.cloud.ibm.com/instances/<id>)
WATSON_TTS_API_KEY=
WATSON_TTS_URL=

# ─── IBM Watson Orchestrate (AI Co-Pilot chat) ────────────────────────────────
# Requires a ServiceId with the IAM "Developer" role on the Orchestrate instance.
# Leave blank to use the built-in physics-based fallback chat automatically.
# WATSON_ORCHESTRATE_URL  → e.g. https://api.us-south.assistant.watson.cloud.ibm.com
# WATSON_ORCHESTRATE_INSTANCE_ID → the Assistant/Orchestrate instance GUID
WATSON_ORCHESTRATE_API_KEY=
WATSON_ORCHESTRATE_URL=
WATSON_ORCHESTRATE_INSTANCE_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default). Change to a PostgreSQL URL for production.
SILICON_DB_URL=sqlite+aiosqlite:///./siliconsentinel.db

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
