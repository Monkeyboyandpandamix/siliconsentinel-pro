modules = ["python-3.11", "nodejs-20"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
WATSON_TTS_URL = "https://api.us-east.text-to-speech.watson.cloud.ibm.com/instances/9f6ed56b-4413-4674-8b27-87f710bea26d"
WATSON_ORCHESTRATE_URL = "https://us-south.watson-orchestrate.cloud.ibm.com"
WATSON_ORCHESTRATE_INSTANCE_ID = "c8a9d776-460e-4c9a-b55f-0a2556febf8e"
WATSON_ORCHESTRATE_AGENT_ID = "c4e8c7f3-51da-4cc7-a9c3-9e055bbd7332"
WATSON_STT_URL = "https://api.us-south.speech-to-text.watson.cloud.ibm.com/instances/326b9d3e-fc83-4429-b8a7-ac48e1bdf488"
